{
  "$schema": "https://biomejs.dev/schemas/1.5.3/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "noInteractiveElementToNoninteractiveRole": "off",
        "noStaticElementInteractions": "off",
        "useSemanticElements": "off",
        "useKeyWithClickEvents": "off",
        "useButtonType": "off",
        "noAutofocus": "off",
        "noLabelWithoutControl": "off",
        "useAltText": "warn",
        "useAnchorContent": "warn"
      },
      "suspicious": {
        "noConsoleLog": "off"
      },
      "style": {
        "useTemplate": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingComma": "es5",
      "semicolons": "always"
    }
  }
}
